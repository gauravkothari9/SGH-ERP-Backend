# =============================================
# SGH ERP — Backend Environment Variables
# Copy this file to .env and fill in values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB — either a local URI or an Atlas SRV URI
# Atlas example:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sgh-erp?retryWrites=true&w=majority&appName=SGH-ERP
MONGO_URI=mongodb://localhost:27017/sgh-erp

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
